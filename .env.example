# =============================================================================
# News Telegram Bot — environment configuration
# Copy this file to .env and fill in the values. NEVER commit your real .env.
# Every secret below is required for production; non-secret tunables have
# sensible defaults and can be left as-is.
# =============================================================================

# --- Telegram ---------------------------------------------------------------
# Bot token from @BotFather (https://t.me/BotFather). Looks like 123456:ABC-...
BOT_TOKEN=

# Channel to publish to. Use @your_channel for a public channel (e.g.
# @CMW_News), or the numeric -100xxxxxxxxxx id for a private one. A bare
# username without @ or a t.me/<name> URL are also accepted (normalised in
# code). The bot MUST be an admin of the channel.
CHANNEL_ID=

# Your personal Telegram numeric id (NOT @username) to receive error alerts.
# Get it from @userinfobot or @getmyid_bot.
ADMIN_ID=

# Backwards-compatible aliases (optional): TELEGRAM_BOT_TOKEN,
# TELEGRAM_CHANNEL_ID and ADMIN_TELEGRAM_ID are also accepted if set.

# --- Database (Neon free Postgres) ------------------------------------------
# Connection string from https://neon.tech (Dashboard -> Connection Details).
# Format: postgresql://user:password@host/dbname?sslmode=require
# Leave EMPTY to run with an in-memory store (dedup won't survive restarts).
DATABASE_URL=

# --- AI providers (all OpenAI-compatible) -----------------------------------
# Order of rotation on 429/quota: Groq -> Cerebras -> OpenRouter -> (Gemini).
# You need at least one key. More keys = more resilience and volume.

# 1) Groq (primary). Key from https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_ENABLED=true

# 2) Cerebras (volume / fallback). Key from https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# CEREBRAS_MODEL=llama-3.3-70b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# CEREBRAS_ENABLED=true

# 3) OpenRouter (safety net). Key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_ENABLED=true

# 4) Gemini — kept in code but DISABLED by default. Enable later if wanted.
GEMINI_API_KEY=
GEMINI_ENABLED=false
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# --- Tunables (safe defaults) -----------------------------------------------
# How often to poll sources, in seconds.
POLL_INTERVAL_SECONDS=30
# Proofread (second AI call) for official / high-impact posts.
ENABLE_EDITOR=true
# Soft daily cap on AI calls to stay within free limits. Near the cap the bot
# prioritises official / high-impact news.
DAILY_AI_CALL_BUDGET=1000
# Max items waiting in the processing queue.
QUEUE_MAX_SIZE=200
# Max NEW items queued per poll cycle (anti-flood burst buffer). Highest-impact
# first; the rest are picked up on the next cycle. No artificial delay between
# posts. Default 3.
MAX_NEW_PER_CYCLE=3
# Only process articles published within this many hours (skips archive spam
# from newly-added feeds). Missing pubDate => skipped. Default 24.
MAX_ARTICLE_AGE_HOURS=24
# Cross-source story dedup window (hours): the same story from multiple
# outlets is posted once within this window. Default 6.
STORY_DEDUP_WINDOW_HOURS=6
# Per-request network timeout (seconds).
REQUEST_TIMEOUT_SECONDS=30
# Logging level: DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
# Channel language (kept in config for a future English channel).
CHANNEL_LANGUAGE=ru
# Set to true to log posts instead of actually sending them (local testing).
DRY_RUN=false
# HTTP port. On Render this is injected automatically; leave default locally.
PORT=10000
